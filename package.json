{
  "name": "family-assistant-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b && pnpm run postbuild",
    "postbuild": "cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "check": "oxfmt --check && oxlint --deny-warnings",
    "setup-family": "tsx --env-file=.env scripts/setup-family.ts",
    "setup-family:local": "tsx --env-file=.env.local scripts/setup-family.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "latest",
    "@dnd-kit/sortable": "latest",
    "@heroicons/react": "latest",
    "@supabase/supabase-js": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/router-plugin": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "latest",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-day-picker": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "remark-gfm": "^4.0.1",
    "sonner": "latest",
    "tailwind-merge": "latest",
    "vaul": "latest",
    "zxing-wasm": "^3.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "latest",
    "@vitest/ui": "latest",
    "jsdom": "latest",
    "oxfmt": "0.51.0",
    "oxlint": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "latest",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
